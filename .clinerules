# SKILL: API Integration (Axios + React Query)
# Applies to: client/src/api/**, client/src/features/**/hooks/**

## Setup — Source of Truth

All API calls go through a central Axios instance, never raw fetch:

```javascript
// client/src/api/axios.js — the only place to configure Axios
import axios from 'axios';

export const api = axios.create({
  baseURL: import.meta.env.VITE_API_URL ?? 'http://localhost:5000/api',
  withCredentials: true,
});

// Request: attach JWT from localStorage
api.interceptors.request.use((config) => {
  const token = localStorage.getItem('accessToken');
  if (token) config.headers.Authorization = `Bearer ${token}`;
  return config;
});

// Response: handle 401 → refresh token flow
api.interceptors.response.use(
  (res) => res,
  async (err) => {
    if (err.response?.status === 401) {
      // trigger token refresh or logout
    }
    return Promise.reject(err);
  }
);
```

## API Service Layer

Each feature has its own service file — never call `api` directly from components or hooks:

```javascript
// client/src/api/services/product.service.js
import { api } from '../axios';

export const productService = {
  getAll: (params) => api.get('/products', { params }).then(r => r.data),
  getBySlug: (slug) => api.get(`/products/${slug}`).then(r => r.data),
  create: (data) => api.post('/products', data).then(r => r.data),
  update: (id, data) => api.put(`/products/${id}`, data).then(r => r.data),
  delete: (id) => api.delete(`/products/${id}`).then(r => r.data),
};
```

## React Query Patterns

### Query hook (read data)
```javascript
// features/product/hooks/useProducts.js
import { useQuery } from '@tanstack/react-query';
import { productService } from '../../../api/services/product.service';

export const PRODUCT_KEYS = {
  all: ['products'],
  list: (params) => ['products', 'list', params],
  detail: (slug) => ['products', 'detail', slug],
};

export function useProducts(params = {}) {
  return useQuery({
    queryKey: PRODUCT_KEYS.list(params),
    queryFn: () => productService.getAll(params),
    staleTime: 1000 * 60 * 5, // 5 min — tune per data volatility
  });
}

export function useProduct(slug) {
  return useQuery({
    queryKey: PRODUCT_KEYS.detail(slug),
    queryFn: () => productService.getBySlug(slug),
    enabled: !!slug,
  });
}
```

### Mutation hook (write data)
```javascript
// features/product/hooks/useProductMutations.js
import { useMutation, useQueryClient } from '@tanstack/react-query';
import { productService } from '../../../api/services/product.service';
import { PRODUCT_KEYS } from './useProducts';

export function useCreateProduct() {
  const qc = useQueryClient();
  return useMutation({
    mutationFn: productService.create,
    onSuccess: () => {
      qc.invalidateQueries({ queryKey: PRODUCT_KEYS.all });
    },
  });
}
```

### Using mutations in components
```jsx
export function CreateProductForm() {
  const { mutate, isPending, error } = useCreateProduct();

  const handleSubmit = (data) => mutate(data);

  return (
    <>
      {error && <Alert severity="error">{error.response?.data?.error?.message}</Alert>}
      <Button onClick={() => handleSubmit(formData)} disabled={isPending}>
        {isPending ? <CircularProgress size={20} /> : 'Create'}
      </Button>
    </>
  );
}
```

## API Integration Checklist
- [ ] All calls go through `client/src/api/axios.js` — never raw fetch/axios
- [ ] Each feature has its own service file in `client/src/api/services/`
- [ ] Query keys use the `*_KEYS` constant object — never inline strings
- [ ] `staleTime` set per endpoint (volatile data = lower, static = higher)
- [ ] `enabled` guard on queries that depend on a param (`enabled: !!slug`)
- [ ] Mutations invalidate relevant query keys on success
- [ ] Error messages extracted from `error.response?.data?.error?.message`
- [ ] Loading states shown with `isPending` / `isLoading`
- [ ] No API calls inside component body — always in a hook

