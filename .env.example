# ╔══════════════════════════════════════════════╗
# ║       E-Commerce Platform — Environment      ║
# ║  Copy this file to .env and fill in values   ║
# ╚══════════════════════════════════════════════╝

# ── App ──
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# ── Database (PostgreSQL) ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecommerce_dev
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# ── JWT Secrets (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))") ──
JWT_ACCESS_SECRET=change_me_to_a_random_32_char_string
JWT_REFRESH_SECRET=change_me_to_a_different_random_string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Razorpay ──
RAZORPAY_KEY_ID=rzp_test_your_key_here
RAZORPAY_KEY_SECRET=whsec_your_secret_here
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_here

# ── Email (SMTP) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
EMAIL_FROM="My Store <noreply@yourdomain.com>"

# ── File Upload ──
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,image/gif

# ── Security ──
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
BCRYPT_ROUNDS=12
