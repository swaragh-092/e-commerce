# Server
NODE_ENV=production
PORT=5000
CLIENT_URL=http://localhost:5173

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecommerce
DB_USER=postgres
DB_PASSWORD=

# Auth
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
VITE_STRIPE_PUBLISHABLE_KEY=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@store.com

# Messaging channel toggles (email is on by default)
EMAIL_ENABLED=true
SMS_ENABLED=false
WHATSAPP_ENABLED=false

# Twilio (SMS + WhatsApp)
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1NXXNXXXXXX
# Sandbox: whatsapp:+14155238886  |  Production: whatsapp:+1YYYYYYYYYY
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Storage
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5




CASHFREE_APP_ID=your_app_id
CASHFREE_SECRET_KEY=your_secret_key
CASHFREE_ENV=sandbox
CASHFREE_API_VERSION=2025-01-01
API_PUBLIC_URL=https://your-api-domain.com/api
CLIENT_URL=https://your-store-domain.com

