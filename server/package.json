{
    "name": "ecommerce-server",
    "version": "1.0.0",
    "description": "E-Commerce Platform — Backend API",
    "main": "index.js",
    "scripts": {
        "start": "node index.js",
        "dev": "nodemon index.js",
        "migrate": "npx sequelize-cli db:migrate",
        "migrate:undo": "npx sequelize-cli db:migrate:undo",
        "seed": "npx sequelize-cli db:seed:all",
        "seed:undo": "npx sequelize-cli db:seed:undo:all",
        "db:reset": "npx sequelize-cli db:drop && npx sequelize-cli db:create && npm run migrate && npm run seed"
    },
    "keywords": [
        "ecommerce",
        "express",
        "sequelize",
        "postgresql"
    ],
    "license": "ISC",
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.21.0",
        "express-rate-limit": "^7.4.0",
        "file-type": "^16.5.4",
        "handlebars": "^4.7.8",
        "helmet": "^7.1.0",
        "joi": "^17.13.3",
        "jsonwebtoken": "^9.0.2",
        "morgan": "^1.10.0",
        "multer": "^1.4.5-lts.1",
        "node-cron": "^3.0.3",
        "nodemailer": "^6.9.14",
        "pg": "^8.12.0",
        "pg-hstore": "^2.3.4",
        "sanitize-html": "^2.13.0",
        "sequelize": "^6.37.3",
        "sharp": "^0.33.4",
        "slugify": "^1.6.6",
        "stripe": "^16.6.0",
        "uuid": "^10.0.0"
    },
    "devDependencies": {
        "nodemon": "^3.1.4",
        "sequelize-cli": "^6.6.2"
    }
}