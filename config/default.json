{
    "general": {
        "storeName": "My Store",
        "storeDescription": "Premium online shopping experience",
        "currency": "USD",
        "currencySymbol": "$",
        "locale": "en-US"
    },
    "theme": {
        "primaryColor": "#6C63FF",
        "secondaryColor": "#FF6584",
        "backgroundColor": "#0F0F1A",
        "surfaceColor": "#1A1A2E",
        "textColor": "#FFFFFF",
        "fontFamily": "Inter",
        "borderRadius": "12px",
        "mode": "dark"
    },
    "features": {
        "wishlist": true,
        "reviews": true,
        "coupons": true,
        "multiCurrency": false,
        "socialLogin": false,
        "guestCheckout": true,
        "emailVerification": false,
        "requirePurchaseForReview": false,
        "showAvailableCoupons": true
    },
    "payments": {
        "razorpayEnabled": true,
        "stripeEnabled": false,
        "payuEnabled": false,
        "cashfreeEnabled": false,
        "codEnabled": true,
        "defaultMethod": "razorpay"
    },
    "sales": {
        "allowScheduling": true,
        "allowBulkSales": true,
        "showCountdown": true,
        "showSaleTiming": true,
        "showSavingsAmount": true,
        "showDiscountPercent": true,
        "showSaleLabel": true,
        "defaultSaleLabel": "Limited Time Offer",
        "endingSoonHours": 24
    },
    "shipping": {
        "method": "flat_rate",
        "flatRate": 5.00,
        "freeThreshold": 50.00
    },
    "tax": {
        "rate": 0.00,
        "inclusive": false,
        "enableCGST": false,
        "cgstRate": 0.09,
        "enableSGST": false,
        "sgstRate": 0.09,
        "enableIGST": false,
        "igstRate": 0.18
    },
    "seo": {
        "titleTemplate": "%s | My Store",
        "defaultDescription": "Shop the best products online at unbeatable prices",
        "ogImage": "/assets/og-image.jpg"
    },
    "logo": {
        "main": "/assets/logo.png",
        "favicon": "/assets/favicon.ico"
    },
    "hero": {
        "title": "Shop the Latest",
        "subtitle": "Discover thousands of products at great prices.",
        "buttonText": "Shop Now",
        "buttonLink": "/products",
        "backgroundType": "gradient",
        "backgroundImage": "",
        "overlayOpacity": 0.5,
        "color": "#ffffff"
    },
    "sku": {
        "prefix": "",
        "separator": "-",
        "includeProductName": true,
        "includeAttributeName": false,
        "includeAttributeValue": true,
        "autoUppercase": true,
        "useRandom": false,
        "randomLength": 4
    },
    "footer": {
        "enabled": true,
        "bgColor": "",
        "fgColor": "",
        "tagline": "Premium online shopping experience.",
        "copyright": "© {year} {storeName}. All rights reserved.",
        "showSocial": false,
        "facebook": "",
        "instagram": "",
        "twitter": "",
        "youtube": "",
        "linkedin": "",
        "showLinks": true,
        "linksTitle": "Quick Links",
        "links": [
            { "label": "Home",     "url": "/" },
            { "label": "Products", "url": "/products" },
            { "label": "Cart",     "url": "/cart" }
        ],
        "showContact": false,
        "email": "",
        "phone": "",
        "address": ""
    },
    "announcement": {
        "enabled": false,
        "text": "Free shipping on orders over $50!",
        "bgColor": "",
        "fgColor": "",
        "link": "",
        "dismissible": true
    },
    "nav": {
        "sticky": true,
        "showCategoryBar": false
    },
    "catalog": {
        "defaultSort": "newest",
        "defaultPageSize": 20,
        "priceRangeMax": 2000,
        "showFilters": true,
        "gridColumns": 4,
        "categoryDepth": 3
    },
    "homepage": {
        "showCategories": true,
        "categoriesTitle": "Shop by Category",
        
        "showNewArrivals": true,
        "newArrivalsTitle": "New Arrivals",
        "newArrivalsCount": 8,
        "newArrivalsLayout": "grid",

        "showFeatured": true,
        "featuredTitle": "Featured Products",
        "featuredCount": 8,
        "featuredLayout": "carousel",

        "showBestSellers": true,
        "bestSellersTitle": "Best Sellers",
        "bestSellersCount": 8,
        "bestSellersLayout": "grid",

        "showOnSale": true,
        "onSaleTitle": "On Sale",
        "onSaleCount": 8,
        "onSaleLayout": "carousel",

        "showBrands": true,
        "brandsTitle": "Shop by Brand",
        "brandsCount": 12
    },
    "productPage": {
        "showSKU": true,
        "showStockBadge": true,
        "addToCartLabel": "Add to Cart",
        "showBuyNowButton": true,
        "buyNowLabel": "Buy Now"
    },
